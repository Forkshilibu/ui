{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "index",
  "dependencies": [
    "class-variance-authority",
    "lucide-react",
    "radix-ui"
  ],
  "devDependencies": [
    "tw-animate-css",
    "shadcn"
  ],
  "registryDependencies": [
    "utils"
  ],
  "files": [],
  "cssVars": {
    "theme": {
      "--color-c-content": "var(--w-c-content)",
      "--color-c-content-disabled": "var(--w-c-content-disabled)",
      "--color-c-contrast": "var(--w-c-contrast)",
      "--color-c-focus": "var(--w-c-focus)",
      "--color-c-alart": "var(--w-c-alart)",
      "--color-btn-orange-a": "var(--w-btn-orange-a)",
      "--color-btn-orange-b": "var(--w-btn-orange-b)",
      "--color-btn-orange-pressed-a": "var(--w-btn-orange-pressed-a)",
      "--color-btn-orange-pressed-b": "var(--w-btn-orange-pressed-b)",
      "--color-btn-gray": "var(--w-btn-gray)",
      "--color-btn-gray-pressed": "var(--w-btn-gray-pressed)",
      "--color-btn-gray-disabled": "var(--w-btn-gray-disabled)",
      "--color-btn-gray-stroke": "var(--w-btn-gray-stroke)",
      "--color-btn-link": "var(--w-btn-link)",
      "--color-btn-link-pressed": "var(--w-btn-link-pressed)",
      "--shadow-orange-glow": "var(--w-shadow-orange-glow)",
      "--spacing-sm": "var(--w-spacing-sm)",
      "--spacing-md-compact": "var(--w-spacing-md-compact)",
      "--spacing-md": "var(--w-spacing-md)",
      "--spacing-lg": "var(--w-spacing-lg)",
      "--spacing-xl": "var(--w-spacing-xl)",
      "--text-label-lg": "14px",
      "--text-label-lg--line-height": "22px",
      "--text-label-md": "13px",
      "--text-label-md--line-height": "20px",
      "--text-label-sm": "12px",
      "--text-label-sm--line-height": "18px"
    }
  },
  "css": {
    "@import \"tw-animate-css\"": {},
    "@import \"shadcn/tailwind.css\"": {},
    "@layer base": {
      "*": {
        "@apply border-border outline-ring/50": {}
      },
      "body": {
        "@apply bg-background text-foreground": {}
      }
    },
    ".style-weibo": {
      "--w-c-brand": "#ff8200",
      "--w-c-brand-dark": "#ea8011",
      "--w-c-content": "#333333",
      "--w-c-content-dark": "#d3d3d3",
      "--w-c-content-disabled": "#939393",
      "--w-c-content-disabled-dark": "#888888",
      "--w-c-contrast": "#ffffff",
      "--w-c-contrast-dark": "#d3d3d3",
      "--w-c-card": "#ffffff",
      "--w-c-card-dark": "#1e1e1e",
      "--w-c-global": "#f5f5f5",
      "--w-c-global-dark": "#151515",
      "--w-c-dividing": "#e6e6e6",
      "--w-c-dividing-dark": "#151515",
      "--w-c-focus": "#f46200",
      "--w-c-focus-dark": "#c95700",
      "--w-c-alart": "#e14123",
      "--w-c-alart-dark": "#d33635",
      "--w-btn-orange-a": "#ff8200",
      "--w-btn-orange-a-dark": "#c76d28",
      "--w-btn-orange-b": "#ffbc33",
      "--w-btn-orange-b-dark": "#ca962b",
      "--w-btn-orange-pressed-a": "#eb7922",
      "--w-btn-orange-pressed-a-dark": "#a7651e",
      "--w-btn-orange-pressed-b": "#efb234",
      "--w-btn-orange-pressed-b-dark": "#ac7c1e",
      "--w-btn-orange-fil": "#ff82000d",
      "--w-btn-orange-fil-dark": "#ea80110d",
      "--w-btn-gray": "#f6f6f6",
      "--w-btn-gray-dark": "#2c2c2c",
      "--w-btn-gray-pressed": "#eaeaea",
      "--w-btn-gray-pressed-dark": "#272727",
      "--w-btn-gray-disabled": "#f6f6f680",
      "--w-btn-gray-disabled-dark": "#2c2c2c80",
      "--w-btn-gray-stroke": "#93939366",
      "--w-btn-gray-stroke-dark": "#8888884d",
      "--w-btn-link": "#7593cb",
      "--w-btn-link-dark": "#5c77a9",
      "--w-btn-link-pressed": "#6785be",
      "--w-btn-link-pressed-dark": "#5771a0",
      "--w-btn-link-stroke": "#546992",
      "--w-btn-link-stroke-dark": "#7a8ba5",
      "--w-radius-full": "999px",
      "--w-radius-medium": "6px",
      "--w-spacing-sm": "6px",
      "--w-spacing-md-compact": "8px",
      "--w-spacing-md": "12px",
      "--w-spacing-lg": "16px",
      "--w-spacing-xl": "24px",
      "--w-shadow-orange-glow": "0 0 12px 0 #ff820026, 0 0 24px 0 #ff820014",
      "&.dark, .dark &": {
        "--w-c-brand": "var(--w-c-brand-dark)",
        "--w-c-content": "var(--w-c-content-dark)",
        "--w-c-content-disabled": "var(--w-c-content-disabled-dark)",
        "--w-c-contrast": "var(--w-c-contrast-dark)",
        "--w-c-card": "var(--w-c-card-dark)",
        "--w-c-global": "var(--w-c-global-dark)",
        "--w-c-dividing": "var(--w-c-dividing-dark)",
        "--w-c-focus": "var(--w-c-focus-dark)",
        "--w-c-alart": "var(--w-c-alart-dark)",
        "--w-btn-orange-a": "var(--w-btn-orange-a-dark)",
        "--w-btn-orange-b": "var(--w-btn-orange-b-dark)",
        "--w-btn-orange-pressed-a": "var(--w-btn-orange-pressed-a-dark)",
        "--w-btn-orange-pressed-b": "var(--w-btn-orange-pressed-b-dark)",
        "--w-btn-orange-fil": "var(--w-btn-orange-fil-dark)",
        "--w-btn-gray": "var(--w-btn-gray-dark)",
        "--w-btn-gray-pressed": "var(--w-btn-gray-pressed-dark)",
        "--w-btn-gray-disabled": "var(--w-btn-gray-disabled-dark)",
        "--w-btn-gray-stroke": "var(--w-btn-gray-stroke-dark)",
        "--w-btn-link": "var(--w-btn-link-dark)",
        "--w-btn-link-pressed": "var(--w-btn-link-pressed-dark)",
        "--w-btn-link-stroke": "var(--w-btn-link-stroke-dark)"
      }
    }
  },
  "type": "registry:style"
}